# planning & reference (local only — never committed). Root-anchored so app
# routes like web/app/docs are NOT swallowed by these.
/docs/
/inspiration/

# secrets & keys
keys/
**/*.pem
**/*.secret_key
.env
**/.env
!**/.env.example

# node (each project is standalone — ignore all node_modules/dist)
**/node_modules/
**/dist/
**/.next/
**/build/
**/out/
**/next-env.d.ts
*.log
npm-debug.log*

# rust / odra
contracts/target/
contracts/wasm/
contracts/.builder*

# os / editor / local tooling
.DS_Store
*.swp
.idea/
.vscode/
.claude/settings.local.json

# autonomous heartbeat runtime state
**/.cycle-state.json

# zk-gate: large/regeneratable ZK artifacts (keep final zkey + vk + witness wasm + proof)
zk-gate/circuits/node_modules/
zk-gate/cli/node_modules/
