# planning & reference (local only, never committed). Root docs/ holds local
# working notes/specs and is never committed; the user-facing docs site lives
# in web/content/docs.
/planning/
/inspiration/
/docs/

# secrets & keys
keys/
**/*.pem
**/*.secret_key
.env
**/.env
!**/.env.example

# node (each project is standalone — ignore all node_modules/dist)
**/node_modules/
**/dist/
**/.next/
**/build/
**/out/
**/next-env.d.ts
*.log
npm-debug.log*

# rust / odra
# contracts/wasm/ is tracked on purpose: it holds the exact deployed artifacts,
# checked against on-chain module_bytes by scripts/verify-onchain.mjs
contracts/target/
contracts/.builder*

# os / editor / local tooling
.DS_Store
*.swp
.idea/
.vscode/
.claude/settings.local.json

# autonomous heartbeat runtime state
**/.cycle-state.json

# zk-gate: large/regeneratable ZK artifacts (keep final zkey + vk + witness wasm + proof)
zk-gate/circuits/node_modules/
zk-gate/cli/node_modules/
zk-gate/circuits/*.ptau
zk-gate/circuits/*.r1cs
zk-gate/circuits/*.sym
zk-gate/circuits/eligibility_0000.zkey

# claros-oracle SDK build output
sdk/dist/
sdk/eia-catalog.json

# Nextra docs search index (generated by `pagefind` in the web postbuild step)
web/public/_pagefind/
