# your ZK credential: the tx hash printed by verify-eligibility-once.ts
# (the agent's compliance gate refuses to run without it)
ELIGIBILITY_VERIFY_TX=

# your feeds: comma-separated feed ids you claimed; specs for custom feeds in a local JSON
CYCLE_ASSETS=EIA.ELEC.GEN_SUN.US48.HOURLY
OPERATOR_FEEDS_FILE=./operator-feeds.json
CYCLE_INTERVAL_MS=3600000

# EIA API key (free: https://www.eia.gov/opendata/register.php)
EIA_API_KEY=
EIA_BASE=https://api.eia.gov
SAN_DIEGO_YEAR=2026

# operator mode: the treasury ledger is first-party only
TREASURY=off
# optional, for the x402 earnings tool
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud
