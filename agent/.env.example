CASPER_NODE_RPC=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test

# your Casper key (generate one: npx tsx src/keygen.ts keys/operator.pem)
AGENT_KEY_PEM_PATH=./keys/operator.pem
AGENT_KEY_ALGO=secp256k1
AGENT_PUBLIC_KEY=

# your LLM: any OpenAI-compatible endpoint works
#   DeepSeek  https://api.deepseek.com          Ollama  http://localhost:11434/v1
#   OpenAI    https://api.openai.com/v1         Groq    https://api.groq.com/openai/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Claros contracts (casper-test)
ATTESTATION_REGISTRY_PACKAGE_HASH=236b510436c60b6a797d175c72c6014de367d43f1de1ca45f580d112f98116cc
FEED_REGISTRY_PACKAGE_HASH=741cc223c14c2c00c9f06d7bb5c4be2f824fbf0c8b09a147bf1835570bddf5b6
ELIGIBILITY_GATE_PACKAGE_HASH=7be33b056c8804e0886cd6f20a75109a0fe92deab505754b97a49fde15aa5227
